---
import Base from './Base.astro';
import { formatDate } from '../lib/utils';

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  type: 'post' | 'til';
}

const { title, date, description, tags = [], type } = Astro.props;
const backHref = type === 'til' ? '/til' : '/posts';
const backLabel = type === 'til' ? '← til' : '← posts';
---

<Base title={title} description={description}>
  <a href={backHref} class="back-link">{backLabel}</a>

  <article>
    <header class="article-header">
      <div class="article-meta">
        <span class:list={['type-badge', type]}>{type === 'til' ? 'TIL' : 'POST'}</span>
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
      </div>
      <h1 class="article-title">{title}</h1>
      {description && <p class="article-desc">{description}</p>}
      {tags.length > 0 && (
        <div class="post-tags" style="margin-top: 0.75rem;">
          {tags.map(tag => (
            <span class:list={['tag', tag]}>{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
